PORT=3000
BASE_URL=http://localhost:3000

# Database configuration
# Options: json, postgres, mysql
DB_PROVIDER=json

# PostgreSQL (when DB_PROVIDER=postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/survey

# MySQL (when DB_PROVIDER=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=survey
MYSQL_PASSWORD=survey123
MYSQL_DATABASE=survey

# Email reminders
REMINDER_AFTER_HOURS=48
SURVEY_EXPIRE_DAYS=7

# Admin authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=xzxz
MANAGER_USERNAME=manager
MANAGER_PASSWORD=123
SESSION_SECRET=please-change-this-secret

# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Survey Bot <no-reply@example.com>
SMTP_TEST_TO=
